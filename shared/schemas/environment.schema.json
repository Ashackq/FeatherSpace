{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EnvironmentConfig",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "map": {
      "type": "object",
      "properties": {
        "width": { "type": "number", "minimum": 1 },
        "height": { "type": "number", "minimum": 1 }
      },
      "required": ["width", "height"],
      "additionalProperties": false
    },
    "visuals": {
      "type": "object",
      "properties": {
        "mapImageUrl": {
          "type": "string",
          "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
        },
        "playerSpriteUrl": {
          "type": "string",
          "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
        },
        "remotePlayerSpriteUrl": {
          "type": "string",
          "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
        },
        "artifactSprites": {
          "type": "object",
          "properties": {
            "whiteboard": {
              "type": "string",
              "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
            },
            "private_room": {
              "type": "string",
              "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
            },
            "table": {
              "type": "string",
              "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
            },
            "notebook": {
              "type": "string",
              "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
            },
            "door": {
              "type": "string",
              "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "communication": {
      "type": "object",
      "properties": {
        "talkRadius": { "type": "number", "minimum": 1 },
        "maxPeers": { "type": "integer", "minimum": 1, "maximum": 8 }
      },
      "required": ["talkRadius", "maxPeers"],
      "additionalProperties": false
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "spriteUrl": {
            "type": "string",
            "pattern": "^(https?://.+\\.(png|jpg|jpeg)|/.+\\.(png|jpg|jpeg)|data:image/(png|jpeg);base64,.+)$"
          },
          "radius": { "type": "number" },
          "scopeId": { "type": "string" },
          "boardId": { "type": "string" },
          "noteId": { "type": "string" },
          "targetRoomId": { "type": "string" },
          "spawnX": { "type": "number" },
          "spawnY": { "type": "number" },
          "label": { "type": "string" }
        },
        "required": ["id", "type", "x", "y"],
        "additionalProperties": true
      }
    }
  },
  "required": ["version", "map", "communication", "objects"],
  "additionalProperties": false
}
